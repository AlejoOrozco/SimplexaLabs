rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: read/write own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Invites: admins can read/write; invited user can read their invite by email
    match /invites/{inviteId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        resource.data.email == request.auth.token.email
      );
      allow create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Meetings: users can read meetings assigned to them; anyone can create (for demo booking)
    match /meetings/{meetingId} {
      allow read: if request.auth != null &&
        resource.data.assignedToUserId == request.auth.uid;
      allow create: if true;  // Guests and logged-in users can book demos
      allow update, delete: if request.auth != null &&
        resource.data.assignedToUserId == request.auth.uid;
    }
  }
}
